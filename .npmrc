# Binarios nativos de @tailwindcss/oxide: con el linker aislado, los opcionales
# a veces no quedan junto a `oxide` y falla require('@tailwindcss/oxide-darwin-arm64').
# Hoisted ≈ node_modules plano como npm; evita el error en macOS/Windows/Linux.
node-linker=hoisted

# Refuerzo: subir paquetes @tailwindcss al raíz de node_modules
public-hoist-pattern[]=*@tailwindcss/*
